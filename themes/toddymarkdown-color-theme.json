{
  "name": "ToddyMarkDown Theme",
  "type": "dark",
  "colors": {},
  "tokenColors": [
    {
      "scope": [
        "keyword.control.block.begin.tmd",
        "keyword.control.block.end.tmd",
        "keyword.control.literal.begin.tmd",
        "keyword.control.literal.end.tmd"
      ],
      "settings": {
        "foreground": "#ff4fd8"
      }
    },
    {
      "scope": [
        "entity.name.function.block.token.tmd",
        "entity.name.function.block.image-mode.tmd"
      ],
      "settings": {
        "foreground": "#d9a441"
      }
    },
    {
      "scope": [
        "string.unquoted.block.title.tmd"
      ],
      "settings": {
        "foreground": "#ff9b42"
      }
    },
    {
      "scope": [
        "markup.heading.1.tmd",
        "markup.heading.1.marker.tmd"
      ],
      "settings": {
        "foreground": "#7ec8ff"
      }
    },
    {
      "scope": [
        "markup.heading.2.tmd",
        "markup.heading.2.marker.tmd"
      ],
      "settings": {
        "foreground": "#3fa9ff"
      }
    },
    {
      "scope": [
        "markup.heading.3.tmd",
        "markup.heading.3.marker.tmd"
      ],
      "settings": {
        "foreground": "#1f6fe5"
      }
    },
    {
      "scope": [
        "punctuation.definition.list.begin.tmd"
      ],
      "settings": {
        "foreground": "#e3c77a"
      }
    },
    {
      "scope": [
        "punctuation.definition.quote.begin.tmd"
      ],
      "settings": {
        "foreground": "#e05757"
      }
    },
    {
      "scope": [
        "support.type.property-name.frontmatter.tmd"
      ],
      "settings": {
        "foreground": "#a4cd54"
      }
    },
    {
      "scope": [
        "string.unquoted.frontmatter.tmd"
      ],
      "settings": {
        "foreground": "#ce9178"
      }
    }
  ]
}
